<body>

    <div class="navbar">
        <div class="logo" onclick="location.href='/'" style="cursor:pointer;">ElectroShop</div>

        <div class="nav-menu">
            <button class="nav-btn" onclick="location.href='/'">Home</button>
            <button class="nav-btn active" onclick="location.href='/shop'">Products</button>

            <!-- CART -->
            <div class="cart-icon" onclick="openCart()">
                <i class="fa-solid fa-cart-shopping"></i>
                <span id="cart-badge">
                    {{ session['cart']|length if session.get('cart') is iterable else 0 }}
                </span>
            </div>

            <!-- Login/Signup Buttons -->
            {% if session.get('user_email') %}
                <a href="/dashboard" style="background: #1e293b; color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none; font-weight: 500;">
                    <i class="fa-solid fa-user"></i> Dashboard
                </a>
                <a href="/logout" style="background: #ef4444; color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none; font-weight: 500;">Logout</a>
            {% else %}
                <a href="/login" style="background: transparent; border: 1px solid #00d2ff; color: #00d2ff; padding: 8px 16px; border-radius: 8px; text-decoration: none; font-weight: 500;">Login</a>
                <a href="/signup" style="background: #00d2ff; color: black; padding: 8px 16px; border-radius: 8px; text-decoration: none; font-weight: 600;">Sign Up</a>
            {% endif %}

        </div>
    </div>


    <div id="cartPanel" class="cart-panel">

        <div class="cart-header">
            <h3>🛒 Cart (<span id="cart-count">0</span>)</h3>
            <span onclick="closeCart()" class="close-cart">✕</span>
        </div>

        <div id="cartItems" style="margin-bottom: 150px;">
        </div>

        <div class="cart-footer">
            <div class="cart-summary">

                <div class="row">
                    <span>Subtotal</span>
                    <span id="subtotal">₹0</span>
                </div>

                <div class="row">
                    <span>Tax (18%)</span>
                    <span id="tax">₹0</span>
                </div>

                <div class="row">
                    <span>Delivery</span>
                    <span>Free</span>
                </div>

                <hr>

                <div class="row total">
                    <span>Total</span>
                    <span id="total">₹0</span>
                </div>

            </div>
            <div class="btn-cart">
                <button onclick="clearCart()" class="clear-btn">Clear Cart</button>
                <!-- <button onclick="location.href='/login'" class="pay-now">Pay Now</button> -->
                <button onclick="location.href='/pay/1'" class="pay-now">Pay Now</button>
            </div>
        </div>
    </div>

    <div class="container">

        <div class="search-filter-bar">
            <input id="searchInput" class="search-input" type="text" placeholder="🔍 Search products ..."
                oninput="searchProduct()">



            <select class="product-select" onchange="filterCategory(this.value)">
                <option value="all">All Categories</option>
                <option value="phone">Smartphones</option>
                <option value="laptop">Laptops</option>
                <option value="tv">TV</option>
                <option value="ac">AC</option>
                <option value="fridge">Fridges</option>
            </select>

            <select class="sort-select" onchange="sortProducts(this.value)">
                <option value="default">Default</option>
                <option value="low">Price : Low → High</option>
                <option value="high">Price : High → Low</option>
                <option value="az">Name : A → Z</option>
                <option value="za">Name : Z → A</option>
            </select>

        </div>
        <div class="grid" id="imageGrid">
            {% for p in products %}

            <div class="card" data-price="{{ p.price }}" data-name="{{ p.name }}" data-category="{{ p.category }}">

                <img src="/static/{{ p.image }}">

                <h3>{{ p.name }}</h3>

                <div class="price">₹{{ p.price }}</div>

                <div class="btn-group">
                    <button class="pay-btn" onclick="addToCart('{{ p.id }}')">Add to Cart 🛒</button>
                    <button class="detail-btn" onclick="location.href='/product/{{ p.id }}'">View Details</button>
                </div>

            </div>

            {% endfor %}
        </div>

    </div>

    <script>


        function openCart() {
            document.getElementById("cartPanel").classList.add("active");
            loadCart();
        }

        function closeCart() {
            document.getElementById("cartPanel").classList.remove("active");
        }

        async function loadCart() {

            let res = await fetch("/cart_data");
            let data = await res.json();

            document.getElementById("cart-count").innerText = data.items.length;

            document.getElementById("subtotal").innerText = "₹" + data.subtotal;
            document.getElementById("tax").innerText = "₹" + data.tax;
            document.getElementById("total").innerText = "₹" + data.total;

            let container = document.getElementById("cartItems");

            container.innerHTML = "";

            if (data.items.length === 0) {

                container.innerHTML = `<p>Your cart is empty</p>`;
                return;

            }

            data.items.forEach(item => {

                container.innerHTML += `

<div class="cart-card">

<img class="cart-img" src="/static/${item.image}">

<div class="cart-details">

<div class="cart-title">${item.name}</div>

<div class="cart-price">₹${item.price}</div>

<div class="cart-qty">

<button class="qty-btn" onclick="updateQty('${item.id}','minus')">-</button>

<span class="qty-num">${item.qty}</span>

<button class="qty-btn" onclick="updateQty('${item.id}','plus')">+</button>

</div>

</div>

<button class="delete-btn" onclick="removeItem('${item.id}')">
<i class="fa fa-trash"></i>
</button>

</div>

`;

            });

        }

        async function updateQty(productId, action) {

            await fetch(`/update_cart/${productId}/${action}`);

            loadCart();

        }
        async function removeItem(productId) {

            await fetch(`/remove_from_cart/${productId}`);

            loadCart();

        }
    </script>

    <script>
        function toggleAdminMenu(event) {
            event.stopPropagation();
            let dropdown = document.getElementById("adminDropdown");
            dropdown.style.display = (dropdown.style.display === "block") ? "none" : "block";
        }

        window.onclick = function (event) {
            let dropdown = document.getElementById("adminDropdown");
            let adminBtn = document.getElementById("adminBtn");

            if (dropdown && !adminBtn.contains(event.target) && !dropdown.contains(event.target)) {
                dropdown.style.display = "none";
            }
        }

        async function addToCart(productId) {
            try {

                const response = await fetch(`/add_to_cart/${productId}`);
                const data = await response.json();

                if (data.status === "success") {

                    const badge = document.getElementById("cart-badge");
                    if (badge) {
                        badge.innerText = data.total_items;
                    }

                    showToast("Item added to cart");

                    if (document.getElementById("cartPanel").classList.contains("active")) {
                        loadCart();
                    }

                } else {
                    alert("Error: " + data.message);
                }

            } catch (error) {
                console.error("Fetch error:", error);
            }
        }
        async function clearCart() {
            await fetch("/clear_cart");
            const badge = document.getElementById("cart-badge");
            if (badge) badge.innerText = "0";
            loadCart();
        }


        function searchProduct() {
            let input = document.getElementById('searchInput').value.toLowerCase();
            let cards = document.querySelectorAll('.card');

            cards.forEach(card => {
                let name = card.dataset.name.toLowerCase();
                if (name.includes(input)) {
                    card.style.display = "block";
                } else {
                    card.style.display = "none";
                }
            });
        }

        // 1. Show the Pop-up
        function toggleAdminMenu(event) {
            event.preventDefault();
            document.getElementById("adminModal").style.display = "flex";
        }

        // 2. Close the Pop-up
        function closeAdminModal() {
            document.getElementById("adminModal").style.display = "none";
        }

        // 3. Check Admin Data via Flask
        async function submitAdminLogin() {
            const user = document.getElementById("adminUser").value;
            const pass = document.getElementById("adminPass").value;

            const response = await fetch('/verify_admin', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: user, password: pass })
            });

            const result = await response.json();

            if (result.success) {
                window.location.href = "/admin"; // Redirect to dashboard
            } else {
                document.getElementById("errorMsg").innerText = "❌ invalid data";
            }
        }
    </script>

    <div id="toast" class="toast-notification"></div>

    <div id="adminModal" class="modal">
        <div class="modal-content">
            <h3 style="color: #00d2ff;">Admin Authentication</h3>
            <input type="text" id="adminUser" placeholder="Admin Name">
            <input type="password" id="adminPass" placeholder="Password">
            <button onclick="submitAdminLogin()">Access Dashboard</button>
            <button onclick="closeAdminModal()" style="background: #30363d; margin-top: 5px;">Cancel</button>
            <p id="admin-error"></p>
        </div>
    </div>

</body>

</html>