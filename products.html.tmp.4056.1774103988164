        }

        /* PRODUCT CARD */

        .card {
            background: linear-gradient(145deg, #0f172a, #020617);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 20px;
            transition: .35s;
