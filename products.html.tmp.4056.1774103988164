            background: #334155;
            transform: translateY(-2px);
        }

        .detail-btn {
            flex: 1.4;
            background: #2563eb;
            border: none;
            padding: 10px;
            border-radius: 10px;
            color: white;
            cursor: pointer;
            transition: .3s;
        }

        .detail-btn:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
        }

        /* CART SLIDER */

        .cart-panel {
            position: fixed;
