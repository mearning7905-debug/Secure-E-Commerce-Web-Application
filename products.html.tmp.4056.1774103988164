            right: -400px;
            width: 380px;
            height: 100%;
            background: #0d1320;
            border-left: 1px solid #1c2633;
            padding: 20px;
            transition: 0.4s;
            z-index: 999;
            overflow-y: auto;
        }

        .cart-panel.active {
            right: 0;
        }

        /* CART SUMMSRY */
        .cart-summary {
            margin-top: 20px;
            font-size: 14px;
        }

