        }

        .modal-content input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            background: #161b22;
            border: 1px solid #30363d;
            color: white;
            border-radius: 8px;
            box-sizing: border-box;
        }

        .modal-content button {
            width: 100%;
            padding: 12px;
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            margin-top: 10px;
        }

        #admin-error {
            color: #ff4d4d;
            font-size: 13px;
            margin-top: 10px;
        }
    </style>

