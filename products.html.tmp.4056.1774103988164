    <style>
        body {
            margin: 0;
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;

            /* dark base */
            background-color: #05070a;

            /* blue glow layers */
            background-image:
                radial-gradient(circle at 20% 50%, rgba(0, 210, 255, 0.25), transparent 40%),
                radial-gradient(circle at 80% 20%, rgba(0, 140, 255, 0.20), transparent 40%),
