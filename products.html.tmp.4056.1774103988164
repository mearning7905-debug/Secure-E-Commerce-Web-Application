        /* MAIN PRODUCT AREA */

        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            gap: 24px;
        }

        /* PRICE RANGE CARD */
        .price-filter {
            background: #0d1320;
