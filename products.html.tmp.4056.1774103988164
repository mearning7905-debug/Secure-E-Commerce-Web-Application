    <script>
        /* CATEGORY FILTER */

        function filterCategory(category) {
            const cards = document.querySelectorAll(".card");

            cards.forEach(card => {

                const productCategory = card.dataset.category ? card.dataset.category.toLowerCase().trim() : "";
                const selectedCategory = category.toLowerCase().trim();

                if (selectedCategory === "all") {
                    card.style.display = "block";
                }
                else if (productCategory.includes(selectedCategory)) {
                    card.style.display = "block";
                }
                else {
                    card.style.display = "none";
                }
            });
        }
        /* SORT PRODUCTS */
        function sortProducts(type) {

            const grid = document.getElementById("imageGrid");
            const cards = Array.from(grid.querySelectorAll(".card"));

            cards.sort((a, b) => {

                let priceA = parseInt(a.dataset.price);
                let priceB = parseInt(b.dataset.price);

                let nameA = a.dataset.name.toLowerCase();
                let nameB = b.dataset.name.toLowerCase();

                if (type === "low") return priceA - priceB;

                if (type === "high") return priceB - priceA;

                if (type === "az") return nameA.localeCompare(nameB);

                if (type === "za") return nameB.localeCompare(nameA);

                return 0;

            });

            grid.innerHTML = "";
            cards.forEach(card => grid.appendChild(card));

        }

        // Toast
        function showToast(message) {

            const toast = document.getElementById("toast");

            toast.innerText = "🛒 " + message;

            toast.classList.add("show");

            setTimeout(() => {
                toast.classList.remove("show");
            }, 2500);

        }

    </script>

