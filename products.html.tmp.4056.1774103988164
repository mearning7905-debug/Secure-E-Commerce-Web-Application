            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            color: #cbd5f1;
        }

        .cart-summary .total {
            font-size: 16px;
            font-weight: bold;
            color: white;
        }

        /* CART HEADER */

        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .close-cart {
            cursor: pointer;
            font-size: 20px;
        }

        /* CART ITEM */
        .cart-card {
            display: flex;
            align-items: center;
            gap: 15px;

            background: linear-gradient(145deg, #0f172a, #020617);

            padding: 14px;
            border-radius: 14px;

            margin-bottom: 15px;
        }

