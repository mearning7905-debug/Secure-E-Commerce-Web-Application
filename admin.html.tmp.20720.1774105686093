<!DOCTYPE html>
<html lang="en">
    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | SmartPay Fraud Detection</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0a0e17 0%, #1a1f2e 50%, #0d1320 100%);
            min-height: 100vh;
            color: #e4e4e7;
        }

        /* Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 32px;
            background: rgba(15, 20, 30, 0.95);
            border-bottom: 1px solid rgba(99, 102, 241, 0.2);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .logo-text {
            font-size: 20px;
            font-weight: 700;
            background: linear-gradient(135deg, #6366f1, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .nav-links a {
            color: #a1a1aa;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: #6366f1;
        }

        .logout-btn {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .logout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(239, 68, 68, 0.4);
        }

        /* Main Container */
        .main-container {
            padding: 32px;
            max-width: 1600px;
            margin: 0 auto;
        }

        /* Stats Section */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 20px;
            margin-bottom: 32px;
        }

        .stat-card {
            background: linear-gradient(135deg, var(--card-bg-start), var(--card-bg-end));
            border: 1px solid var(--card-border);
            border-left: 4px solid var(--accent-color);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: transform 0.3s, box-shadow 0.3s;
            position: relative;
            overflow: hidden;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px var(--card-shadow);
        }

        /* Light RGB colored backgrounds for each card */
        .stat-card.users {
            --accent-color: #8b5cf6;
            --card-bg-start: rgba(139, 92, 246, 0.08);
            --card-bg-end: rgba(139, 92, 246, 0.02);
            --card-border: rgba(139, 92, 246, 0.15);
            --card-shadow: rgba(139, 92, 246, 0.15);
            --icon-bg: rgba(139, 92, 246, 0.15);
            --icon-color: #8b5cf6;
        }

        .stat-card.transactions {
            --accent-color: #3b82f6;
            --card-bg-start: rgba(59, 130, 246, 0.08);
            --card-bg-end: rgba(59, 130, 246, 0.02);
            --card-border: rgba(59, 130, 246, 0.15);
            --card-shadow: rgba(59, 130, 246, 0.15);
            --icon-bg: rgba(59, 130, 246, 0.15);
            --icon-color: #3b82f6;
        }

        .stat-card.blocked {
            --accent-color: #f97316;
            --card-bg-start: rgba(249, 115, 22, 0.08);
            --card-bg-end: rgba(249, 115, 22, 0.02);
            --card-border: rgba(249, 115, 22, 0.15);
            --card-shadow: rgba(249, 115, 22, 0.15);
            --icon-bg: rgba(249, 115, 22, 0.15);
            --icon-color: #f97316;
        }

        .stat-card.success {
            --accent-color: #10b981;
            --card-bg-start: rgba(16, 185, 129, 0.08);
            --card-bg-end: rgba(16, 185, 129, 0.02);
            --card-border: rgba(16, 185, 129, 0.15);
            --card-shadow: rgba(16, 185, 129, 0.15);
            --icon-bg: rgba(16, 185, 129, 0.15);
            --icon-color: #10b981;
        }

        .stat-card.revenue {
            --accent-color: #a3703f;
            --card-bg-start: rgba(163, 112, 63, 0.08);
            --card-bg-end: rgba(163, 112, 63, 0.02);
            --card-border: rgba(163, 112, 63, 0.15);
            --card-shadow: rgba(163, 112, 63, 0.15);
            --icon-bg: rgba(163, 112, 63, 0.15);
            --icon-color: #a3703f;
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 700;
            background: var(--icon-bg);
            color: var(--icon-color);
            flex-shrink: 0;
        }

        .stat-content {
            flex: 1;
        }

        .stat-label {
            font-size: 12px;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
            font-weight: 500;
        }

        .stat-value {
            font-size: 26px;
            font-weight: 700;
            color: #fafafa;
        }

        /* Content Grid */
        .content-grid {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 24px;
        }

        /* Users Sidebar */
        .users-panel {
            background: rgba(30, 35, 50, 0.8);
            border: 1px solid rgba(99, 102, 241, 0.15);
            border-radius: 16px;
            overflow: hidden;
            max-height: calc(100vh - 300px);
            display: flex;
            flex-direction: column;
        }

        .panel-header {
            padding: 20px;
            border-bottom: 1px solid rgba(99, 102, 241, 0.1);
            background: rgba(20, 25, 40, 0.5);
        }

        .panel-title {
            font-size: 16px;
            font-weight: 600;
            color: #fafafa;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .search-box {
            display: flex;
            align-items: center;
            background: rgba(15, 20, 30, 0.8);
            border: 1px solid rgba(99, 102, 241, 0.2);
            border-radius: 10px;
            padding: 0 14px;
            transition: border-color 0.3s;
        }

        .search-box:focus-within {
            border-color: #6366f1;
        }

        .search-box input {
            flex: 1;
            background: none;
            border: none;
            padding: 12px 10px;
            color: #fafafa;
            font-size: 14px;
            outline: none;
        }

        .search-box input::placeholder {
            color: #71717a;
        }

        .search-icon {
            color: #71717a;
        }

        .users-list {
            flex: 1;
            overflow-y: auto;
            padding: 12px;
        }

        .users-list::-webkit-scrollbar {
            width: 6px;
        }

        .users-list::-webkit-scrollbar-track {
            background: transparent;
        }

        .users-list::-webkit-scrollbar-thumb {
            background: rgba(99, 102, 241, 0.3);
            border-radius: 3px;
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 8px;
            border: 1px solid transparent;
        }

        .user-card:hover {
            background: rgba(99, 102, 241, 0.1);
            border-color: rgba(99, 102, 241, 0.2);
        }

        .user-card.active {
            background: rgba(99, 102, 241, 0.15);
            border-color: #6366f1;
        }

        .user-avatar {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 16px;
            color: white;
            flex-shrink: 0;
        }

        .user-info {
            flex: 1;
            min-width: 0;
        }

        .user-name {
            font-weight: 600;
            font-size: 14px;
            color: #fafafa;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-email {
            font-size: 12px;
            color: #71717a;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-active {
            background: rgba(16, 185, 129, 0.2);
            color: #10b981;
        }

        .badge-count {
            background: rgba(99, 102, 241, 0.2);
            color: #a78bfa;
        }

        /* Details Panel */
        .details-panel {
            background: rgba(30, 35, 50, 0.8);
            border: 1px solid rgba(99, 102, 241, 0.15);
            border-radius: 16px;
            overflow: hidden;
        }

        .details-header {
            padding: 24px;
            border-bottom: 1px solid rgba(99, 102, 241, 0.1);
            background: rgba(20, 25, 40, 0.5);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .details-user {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .details-avatar {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 22px;
            color: white;
        }

        .details-name {
            font-size: 20px;
            font-weight: 700;
            color: #fafafa;
            margin-bottom: 4px;
        }

        .details-id {
            font-size: 13px;
            color: #71717a;
        }

        .action-buttons {
            display: flex;
            gap: 12px;
        }

        .action-btn {
            padding: 10px 18px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-delete {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
        }

        .btn-export {
            background: rgba(16, 185, 129, 0.15);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .btn-export:hover {
            background: #10b981;
            color: white;
        }

        /* Details Content */
        .details-content {
            padding: 24px;
        }

        .placeholder-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 80px 20px;
            color: #71717a;
        }

        .placeholder-icon {
            font-size: 64px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        .placeholder-text {
            font-size: 16px;
        }

        /* Info Grid */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .info-card {
            background: rgba(15, 20, 30, 0.6);
            border: 1px solid rgba(99, 102, 241, 0.1);
            border-radius: 12px;
            padding: 18px;
        }

        .info-label {
            font-size: 12px;
            color: #71717a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .info-value {
            font-size: 16px;
            font-weight: 600;
            color: #fafafa;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Transactions Section */
        .transactions-section {
            margin-top: 24px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .section-title {
            font-size: 16px;
            font-weight: 600;
            color: #fafafa;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .transactions-table {
            width: 100%;
            border-collapse: collapse;
        }

        .transactions-table th {
            text-align: left;
            padding: 14px 16px;
            font-size: 12px;
            font-weight: 600;
            color: #71717a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: rgba(15, 20, 30, 0.6);
            border-bottom: 1px solid rgba(99, 102, 241, 0.1);
        }

        .transactions-table th:first-child {
            border-radius: 10px 0 0 0;
        }

        .transactions-table th:last-child {
            border-radius: 0 10px 0 0;
        }

        .transactions-table td {
            padding: 16px;
            font-size: 14px;
            border-bottom: 1px solid rgba(99, 102, 241, 0.05);
        }

        .transactions-table tbody tr {
            transition: background 0.2s;
        }

        .transactions-table tbody tr:hover {
            background: rgba(99, 102, 241, 0.05);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-success {
            background: rgba(16, 185, 129, 0.15);
            color: #10b981;
        }

        .status-blocked {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
        }

        .amount-cell {
            font-weight: 600;
            color: #fafafa;
        }

        .no-transactions {
            text-align: center;
            padding: 40px;
            color: #71717a;
        }

        .hidden {
            display: none !important;
        }

        /* Responsive */
        @media (max-width: 1400px) {
            .stats-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media (max-width: 1024px) {
            .content-grid {
                grid-template-columns: 1fr;
            }

            .users-panel {
                max-height: 400px;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 640px) {
            .navbar {
                padding: 12px 16px;
            }

            .main-container {
                padding: 16px;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .stat-card {
                padding: 16px;
            }

            .stat-value {
                font-size: 22px;
            }
        }
    </style>
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar">
        <a href="#" class="logo">
            <div class="logo-icon">S</div>
            <span class="logo-text">SmartPay Admin</span>
        </a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/history">Analytics</a>
            <button class="logout-btn" onclick="window.location.href='/logout'">Logout</button>
        </div>
    </nav>

    <!-- Main Container -->
    <div class="main-container">
        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card users">
                <div class="stat-icon">U</div>
                <div class="stat-content">
                    <div class="stat-label">Total Users</div>
                    <div class="stat-value">{{ stats.total_users }}</div>
                </div>
            </div>
            <div class="stat-card transactions">
                <div class="stat-icon">T</div>
                <div class="stat-content">
                    <div class="stat-label">Total Transactions</div>
                    <div class="stat-value">{{ stats.total_transactions }}</div>
                </div>
            </div>
            <div class="stat-card blocked">
                <div class="stat-icon">!</div>
                <div class="stat-content">
                    <div class="stat-label">Fraud Blocked</div>
                    <div class="stat-value">{{ stats.blocked_count }}</div>
                </div>
            </div>
            <div class="stat-card success">
                <div class="stat-icon">%</div>
                <div class="stat-content">
                    <div class="stat-label">Success Rate</div>
                    <div class="stat-value">{{ stats.success_rate }}%</div>
                </div>
            </div>
            <div class="stat-card revenue">
                <div class="stat-icon">R</div>
                <div class="stat-content">
                    <div class="stat-label">Total Revenue</div>
                    <div class="stat-value">{{ stats.total_revenue }}</div>
                </div>
            </div>
        </div>

        <!-- Content Grid -->
        <div class="content-grid">
            <!-- Users Panel -->
            <div class="users-panel">
                <div class="panel-header">
                    <div class="panel-title">
                        <span>Registered Users</span>
                        <span class="user-badge badge-count">{{ stats.total_users }}</span>
                    </div>
                    <div class="search-box">
                        <span class="search-icon">O</span>
                        <input type="text" id="userSearch" placeholder="Search users..." onkeyup="filterUsers()">
                    </div>
                </div>
                <div class="users-list" id="usersList">
                    {% for user in db_users %}
                    <div class="user-card" data-name="{{ user.username }}" data-email="{{ user.email }}"
                        onclick="viewUser('{{ user.id }}', '{{ user.username }}', '{{ user.email }}', '{{ user.mobile }}', '{{ user.card }}')">
                        <div class="user-avatar">{{ user.username[0]|upper }}</div>
                        <div class="user-info">
                            <div class="user-name">{{ user.username }}</div>
                            <div class="user-email">{{ user.email }}</div>
                        </div>
                        <span class="user-badge badge-active">Active</span>
                    </div>
                    {% endfor %}

                    {% if db_users|length == 0 %}
                    <div class="no-transactions">No users registered yet</div>
                    {% endif %}
                </div>
            </div>

            <!-- Details Panel -->
            <div class="details-panel">
                <!-- Placeholder -->
                <div id="placeholder-content" class="details-content">
                    <div class="placeholder-content">
                        <div class="placeholder-icon">U</div>
                        <div class="placeholder-text">Select a user to view details</div>
                    </div>
                </div>

                <!-- User Details -->
                <div id="user-details" class="hidden">
                    <div class="details-header">
                        <div class="details-user">
                            <div class="details-avatar" id="display-avatar">M</div>
                            <div>
                                <div class="details-name" id="display-name">User Name</div>
                                <div class="details-id">ID: <span id="display-id">1</span></div>
                            </div>
                        </div>
                        <div class="action-buttons">
                            <button class="action-btn btn-export" onclick="exportUserData()">
                                <span>E</span> Export
                            </button>
                            <button class="action-btn btn-delete" onclick="deleteUser()">
                                <span>X</span> Delete User
                            </button>
                        </div>
                    </div>

                    <div class="details-content">
                        <!-- Info Grid -->
                        <div class="info-grid">
                            <div class="info-card">
                                <div class="info-label">Email Address</div>
                                <div class="info-value" id="display-email">user@example.com</div>
                            </div>
                            <div class="info-card">
                                <div class="info-label">Mobile Number</div>
                                <div class="info-value" id="display-mobile">+91 XXXXXXXXXX</div>
                            </div>
                            <div class="info-card">
                                <div class="info-label">Card Number</div>
                                <div class="info-value" id="display-card">**** **** **** 1234</div>
                            </div>
                            <div class="info-card">
                                <div class="info-label">Account Status</div>
                                <div class="info-value">
                                    <span class="status-badge status-success">Active</span>
                                </div>
                            </div>
                        </div>

                        <!-- Transactions Section -->
                        <div class="transactions-section">
                            <div class="section-header">
                                <div class="section-title">
                                    <span>T</span> Transaction History
                                </div>
                            </div>

                            <table class="transactions-table">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th>Amount</th>
                                        <th>Bank</th>
                                        <th>Status</th>
                                        <th>Date & Time</th>
                                    </tr>
                                </thead>
                                <tbody id="transactions-body">
                                    <!-- Filled by JS -->
                                </tbody>
                            </table>

                            <div id="no-transactions" class="no-transactions hidden">
                                No transactions found for this user
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // @ts-nocheck
        const userTransactions = {{ user_transactions | tojson | safe }};
        let selectedUserData = null;

        // Filter Users
        function filterUsers() {
            const search = document.getElementById('userSearch').value.toLowerCase();
            const cards = document.querySelectorAll('.user-card');

            cards.forEach(card => {
                const name = card.dataset.name.toLowerCase();
                const email = card.dataset.email.toLowerCase();

                if (name.includes(search) || email.includes(search)) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // View User Details
        function viewUser(id, username, email, mobile, card) {
            // Remove active class from all cards
            document.querySelectorAll('.user-card').forEach(c => c.classList.remove('active'));

            // Add active class to clicked card
            event.currentTarget.classList.add('active');

            // Hide placeholder, show details
            document.getElementById('placeholder-content').classList.add('hidden');
            document.getElementById('user-details').classList.remove('hidden');

            // Set user data
            document.getElementById('display-avatar').textContent = username.charAt(0).toUpperCase();
            document.getElementById('display-name').textContent = username;
            document.getElementById('display-id').textContent = id;
            document.getElementById('display-email').textContent = email;
            document.getElementById('display-mobile').textContent = mobile;
            document.getElementById('display-card').textContent = '**** **** **** ' + card.slice(-4);

            // Store for later use
            selectedUserData = { id, username, email, mobile, card };
            window.selectedUserId = id;

            // Load transactions
            loadTransactions(email);
        }

        // Load Transactions
        function loadTransactions(email) {
            const tbody = document.getElementById('transactions-body');
            const noTx = document.getElementById('no-transactions');

            tbody.innerHTML = '';

            if (userTransactions[email] && userTransactions[email].length > 0) {
                noTx.classList.add('hidden');
                tbody.parentElement.classList.remove('hidden');

                userTransactions[email].forEach(tx => {
                    const isSuccess = tx.status.includes('Successful') || tx.status.includes('Success');
                    const statusClass = isSuccess ? 'status-success' : 'status-blocked';
                    const statusIcon = isSuccess ? 'O' : 'X';
                    const statusText = isSuccess ? 'Success' : 'Blocked';

                    tbody.innerHTML += `
                        <tr>
                            <td>${tx.item_name || 'Product'}</td>
                            <td class="amount-cell">${tx.amount}</td>
                            <td>${tx.bank_name || 'N/A'}</td>
                            <td>
                                <span class="status-badge ${statusClass}">
                                    <span>${statusIcon}</span> ${statusText}
                                </span>
                            </td>
                            <td>${tx.time}</td>
                        </tr>
                    `;
                });
            } else {
                noTx.classList.remove('hidden');
            }
        }

        // Delete User
        function deleteUser() {
            if (!window.selectedUserId) {
                alert("Please select a user first");
                return;
            }

            if (!confirm("Are you sure you want to delete this user? This action cannot be undone.")) {
                return;
            }

            fetch("/delete-user/" + window.selectedUserId, {
                method: "POST"
            })
                .then(res => res.json())
                .then(data => {
                    alert(data.message);
                    location.reload();
                })
                .catch(err => {
                    alert("Error deleting user");
                });
        }

        // Export User Data
        function exportUserData() {
            if (!selectedUserData) {
                alert("Please select a user first");
                return;
            }

            const data = {
                ...selectedUserData,
                transactions: userTransactions[selectedUserData.email] || []
            };

            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `user_${selectedUserData.username}_data.json`;
            a.click();
            URL.revokeObjectURL(url);
        }
    </script>
</body>

</html>
