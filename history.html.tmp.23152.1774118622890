<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Risk Intelligence | SecurePay Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #0f1117;
            min-height: 100vh;
            color: #e4e4e7;
            display: flex;
        }

        /* =============== SIDEBAR =============== */
        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, #0a0e27 0%, #161a2f 100%);
            border-right: 2px solid rgba(99, 102, 241, 0.2);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 200;
            box-shadow: 2px 0 15px rgba(0, 0, 0, 0.3);
        }

        .sidebar-header {
            padding: 28px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            border-bottom: 2px solid rgba(99, 102, 241, 0.15);
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(139, 92, 246, 0.05));
        }

        .sidebar-logo {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, #7c3aed, #6366f1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 800;
            color: white;
            box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
        }

        .sidebar-brand {
            font-size: 20px;
            font-weight: 800;
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 0.5px;
        }

        .sidebar-label {
            padding: 24px 20px 12px;
            font-size: 10px;
            font-weight: 700;
            color: #a1a1aa;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .sidebar-nav {
            flex: 1;
            padding: 8px 12px;
            overflow-y: auto;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border-radius: 12px;
            color: #cbd5e1;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 6px;
            border: 1px solid transparent;
            background: none;
            width: 100%;
            text-align: left;
            position: relative;
        }

        .nav-item:hover {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(139, 92, 246, 0.1));
            color: #fbbf24;
            border-color: rgba(251, 191, 36, 0.3);
            transform: translateX(4px);
        }

        .nav-item.active {
            background: linear-gradient(135deg, rgba(251, 191, 36, 0.2), rgba(245, 158, 11, 0.15));
            color: #fbbf24;
            font-weight: 600;
            border-color: #fbbf24;
            box-shadow: inset 0 0 10px rgba(251, 191, 36, 0.1);
        }

        .nav-item i {
            width: 20px;
            text-align: center;
            font-size: 17px;
            transition: all 0.3s;
        }

        .nav-item:hover i {
            transform: scale(1.15);
        }

        .nav-item.active i {
            color: #fbbf24;
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 2px solid rgba(99, 102, 241, 0.1);
            background: linear-gradient(180deg, transparent, rgba(139, 92, 246, 0.05));
        }

        .nav-item.logout-item {
            color: #f87171;
        }

        .nav-item.logout-item:hover {
            background: rgba(239, 68, 68, 0.12);
            color: #fca5a5;
            border-color: #fca5a5;
        }

        /* =============== MAIN AREA =============== */
        .main-area {
            flex: 1;
            margin-left: 280px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* =============== TOP BAR =============== */
        .top-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 32px;
            background: rgba(22, 26, 37, 0.95);
            border-bottom: 1px solid rgba(99, 102, 241, 0.1);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .top-search {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(15, 17, 23, 0.8);
            border: 1px solid rgba(99, 102, 241, 0.15);
            border-radius: 10px;
            padding: 0 16px;
            width: 320px;
            transition: border-color 0.3s;
        }

        .top-search:focus-within {
            border-color: #6366f1;
        }

        .top-search i {
            color: #52525b;
            font-size: 14px;
        }

        .top-search input {
            flex: 1;
            background: none;
            border: none;
            padding: 10px 8px;
            color: #fafafa;
            font-size: 14px;
            outline: none;
            font-family: 'Inter', sans-serif;
        }

        .top-search input::placeholder {
            color: #52525b;
        }

        .top-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .top-icon-btn {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(15, 17, 23, 0.6);
            border: 1px solid rgba(99, 102, 241, 0.1);
            color: #a1a1aa;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 16px;
        }

        .top-icon-btn:hover {
            background: rgba(99, 102, 241, 0.1);
            color: #a78bfa;
            border-color: rgba(99, 102, 241, 0.3);
        }

        .top-avatar {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 15px;
            color: white;
            cursor: pointer;
            border: 2px solid rgba(99, 102, 241, 0.3);
        }

        /* =============== PAGE CONTENT =============== */
        .page-content {
            padding: 28px 32px;
            flex: 1;
        }

        /* =============== WELCOME BANNER =============== */
        .welcome-banner {
            background: linear-gradient(135deg, #4338ca 0%, #6366f1 40%, #7c3aed 100%);
            border-radius: 18px;
            padding: 36px 40px;
            margin-bottom: 28px;
            position: relative;
            overflow: hidden;
        }

        .welcome-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 50%;
        }

        .welcome-banner::after {
            content: '';
            position: absolute;
            bottom: -30%;
            right: 10%;
            width: 200px;
            height: 200px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 50%;
        }

        .welcome-banner h1 {
            font-size: 28px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 8px;
            position: relative;
            z-index: 1;
        }

        .welcome-banner p {
            color: rgba(255, 255, 255, 0.8);
            font-size: 15px;
            line-height: 1.6;
            max-width: 600px;
            position: relative;
            z-index: 1;
        }

        /* =============== STAT CARDS =============== */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            border-radius: 16px;
            padding: 22px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
            transition: transform 0.25s, box-shadow 0.25s;
        }

        .stat-card:hover {
            transform: translateY(-3px);
        }

        .stat-card .stat-text {
            z-index: 1;
        }

        .stat-card .stat-label {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 6px;
        }

        .stat-card .stat-value {
            font-size: 30px;
            font-weight: 800;
        }

        .stat-card .stat-icon {
            font-size: 28px;
            opacity: 0.9;
            z-index: 1;
        }

        .stat-card.card-total {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            color: white;
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.25);
        }

        .stat-card.card-success {
            background: linear-gradient(135deg, #059669, #10b981);
            color: white;
            box-shadow: 0 8px 24px rgba(16, 185, 129, 0.25);
        }

        .stat-card.card-fraud {
            background: linear-gradient(135deg, #dc2626, #ef4444);
            color: white;
            box-shadow: 0 8px 24px rgba(239, 68, 68, 0.25);
        }

        .stat-card.card-revenue {
            background: linear-gradient(135deg, #d97706, #f59e0b);
            color: white;
            box-shadow: 0 8px 24px rgba(245, 158, 11, 0.25);
        }

        /* =============== CHARTS GRID =============== */
        .charts-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 24px;
            margin-bottom: 28px;
        }

        .panel {
            background: #161a25;
            border: 1px solid rgba(99, 102, 241, 0.1);
            border-radius: 16px;
            overflow: hidden;
        }

        .panel-header {
            padding: 20px 24px;
            border-bottom: 1px solid rgba(99, 102, 241, 0.08);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .panel-title {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 16px;
            font-weight: 600;
            color: #fafafa;
        }

        .panel-title i {
            color: #6366f1;
            font-size: 18px;
        }

        .panel-body {
            padding: 24px;
        }

        .chart-container {
            height: 280px;
            position: relative;
        }

        /* =============== TRANSACTIONS TABLE =============== */
        .table-panel {
            margin-top: 0;
        }

        .filter-row {
            display: flex;
            gap: 16px;
            padding: 16px 24px;
            border-bottom: 1px solid rgba(99, 102, 241, 0.08);
            flex-wrap: wrap;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .filter-group label {
            font-size: 11px;
            font-weight: 600;
            color: #71717a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .filter-input {
            background: rgba(15, 17, 23, 0.8);
            border: 1px solid rgba(99, 102, 241, 0.15);
            border-radius: 8px;
            padding: 8px 12px;
            color: #fafafa;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: border-color 0.3s;
        }

        .filter-input:focus {
            border-color: #6366f1;
        }

        .transactions-table {
            width: 100%;
            border-collapse: collapse;
        }

        .transactions-table th {
            text-align: left;
            padding: 14px 24px;
            font-size: 12px;
            font-weight: 600;
            color: #71717a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: rgba(15, 17, 23, 0.5);
            border-bottom: 1px solid rgba(99, 102, 241, 0.08);
        }

        .transactions-table td {
            padding: 16px 24px;
            font-size: 14px;
            border-bottom: 1px solid rgba(99, 102, 241, 0.06);
        }

        .transactions-table tr:hover {
            background: rgba(99, 102, 241, 0.04);
        }

        .tx-id {
            color: #6366f1;
            font-weight: 600;
        }

        .tx-merchant {
            font-weight: 600;
            color: #fafafa;
        }

        .tx-amount {
            font-weight: 700;
            color: #fafafa;
        }

        .tx-time {
            color: #71717a;
            font-size: 13px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-badge.success {
            background: rgba(16, 185, 129, 0.15);
            color: #10b981;
        }

        .status-badge.fraud {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
        }

        .status-badge i {
            font-size: 10px;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #71717a;
        }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 16px;
            color: #52525b;
        }

        .empty-state h3 {
            font-size: 18px;
            font-weight: 600;
            color: #a1a1aa;
            margin-bottom: 8px;
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
            .charts-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .main-area {
                margin-left: 0;
            }
            .stats-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">S</div>
            <span class="sidebar-brand">SecurePay</span>
        </div>
        <div class="sidebar-label">Menu</div>
        <nav class="sidebar-nav">
            <a href="/dashboard" class="nav-item">
                <i class="fas fa-home"></i> Dashboard
            </a>
            <a href="/history" class="nav-item active">
                <i class="fas fa-chart-line"></i> Analytics
            </a>
            <a href="/admin_dashboard" class="nav-item">
                <i class="fas fa-users-cog"></i> Admin Panel
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="/logout" class="nav-item logout-item">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </aside>

    <!-- MAIN AREA -->
    <main class="main-area">
        <!-- TOP BAR -->
        <header class="top-bar">
            <div class="top-search">
                <i class="fas fa-search"></i>
                <input type="text" id="mainSearch" placeholder="Search transactions..." onkeyup="runFilters()">
            </div>
            <div class="top-actions">
                <button class="top-icon-btn"><i class="fas fa-bell"></i></button>
                <button class="top-icon-btn"><i class="fas fa-cog"></i></button>
                <div class="top-avatar">A</div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <div class="page-content">
            <!-- WELCOME BANNER -->
            <div class="welcome-banner">
                <h1><i class="fas fa-shield-halved"></i> Risk Intelligence Dashboard</h1>
                <p>Real-time fraud analysis and threat pattern monitoring. Track transaction anomalies and protect your payment ecosystem.</p>
            </div>

            <!-- STAT CARDS -->
            <div class="stats-row">
                <div class="stat-card card-total">
                    <div class="stat-text">
                        <div class="stat-label">Total Transactions</div>
                        <div class="stat-value">{{ total }}</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-receipt"></i></div>
                </div>
                <div class="stat-card card-success">
                    <div class="stat-text">
                        <div class="stat-label">Legitimate</div>
                        <div class="stat-value">{{ success }}</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                </div>
                <div class="stat-card card-fraud">
                    <div class="stat-text">
                        <div class="stat-label">Fraud Detected</div>
                        <div class="stat-value">{{ failed }}</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
                </div>
                <div class="stat-card card-revenue">
                    <div class="stat-text">
                        <div class="stat-label">Protected Amount</div>
                        <div class="stat-value">₹{{ success_amount }}</div>
                    </div>
                    <div class="stat-icon"><i class="fas fa-shield-alt"></i></div>
                </div>
            </div>

            <!-- CHARTS -->
            <div class="charts-grid">
                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">
                            <i class="fas fa-chart-pie"></i>
                            Fraud vs Legitimate
                        </div>
                    </div>
                    <div class="panel-body">
                        <div class="chart-container">
                            <canvas id="doughnutChart"></canvas>
                        </div>
                    </div>
                </div>
                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">
                            <i class="fas fa-chart-area"></i>
                            Transaction Trends
                        </div>
                    </div>
                    <div class="panel-body">
                        <div class="chart-container">
                            <canvas id="trendChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TRANSACTIONS TABLE -->
            <div class="panel table-panel">
                <div class="panel-header">
                    <div class="panel-title">
                        <i class="fas fa-list-ul"></i>
                        Recent Transactions
                    </div>
                </div>
                <div class="filter-row">
                    <div class="filter-group">
                        <label>From Date</label>
                        <input type="date" id="fDate" class="filter-input" onchange="runFilters()">
                    </div>
                    <div class="filter-group">
                        <label>To Date</label>
                        <input type="date" id="tDate" class="filter-input" onchange="runFilters()">
                    </div>
                    <div class="filter-group">
                        <label>Min Amount (₹)</label>
                        <input type="number" id="minA" class="filter-input" placeholder="0" onkeyup="runFilters()">
                    </div>
                    <div class="filter-group">
                        <label>Max Amount (₹)</label>
                        <input type="number" id="maxA" class="filter-input" placeholder="999999" onkeyup="runFilters()">
                    </div>
                </div>

                {% if history %}
                <table class="transactions-table" id="dataTable">
                    <thead>
                        <tr>
                            <th>Transaction ID</th>
                            <th>Merchant</th>
                            <th>Amount</th>
                            <th>Date & Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for tx in history %}
                        <tr class="row-item" data-amt="{{ tx.amount }}" data-date="{{ tx.time.split(' ')[0] }}">
                            <td class="tx-id">TXN-{{ tx.id }}</td>
                            <td class="tx-merchant">{{ tx.bank_name or 'Global Store' }}</td>
                            <td class="tx-amount">₹{{ tx.amount }}</td>
                            <td class="tx-time">{{ tx.time }}</td>
                            <td>
                                {% if 'Successful' in tx.status %}
                                <span class="status-badge success">
                                    <i class="fas fa-check"></i> Legitimate
                                </span>
                                {% else %}
                                <span class="status-badge fraud">
                                    <i class="fas fa-times"></i> Fraud
                                </span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <h3>No Transactions Found</h3>
                    <p>Transaction history will appear here once payments are processed.</p>
                </div>
                {% endif %}
            </div>
        </div>
    </main>

    <script>
        // Doughnut Chart
        new Chart(document.getElementById('doughnutChart'), {
            type: 'doughnut',
            data: {
                labels: ['Legitimate', 'Fraud'],
                datasets: [{
                    data: [{{ success }}, {{ failed }}],
                    backgroundColor: ['#10b981', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                cutout: '75%',
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: '#a1a1aa',
                            padding: 20,
                            font: { size: 13, family: 'Inter' },
                            usePointStyle: true
                        }
                    }
                }
            }
        });

        // Trend Chart
        new Chart(document.getElementById('trendChart'), {
            type: 'line',
            data: {
                labels: ['Day 1', 'Day 2', 'Day 3', 'Day 4', 'Day 5', 'Day 6', 'Today'],
                datasets: [
                    {
                        label: 'Fraud Alerts',
                        data: [2, 5, 3, 8, 4, 6, {{ failed }}],
                        borderColor: '#ef4444',
                        backgroundColor: 'rgba(239, 68, 68, 0.1)',
                        tension: 0.4,
                        fill: true,
                        pointRadius: 5,
                        pointBackgroundColor: '#ef4444'
                    },
                    {
                        label: 'Total Activity',
                        data: [15, 20, 18, 25, 22, 30, {{ total }}],
                        borderColor: '#6366f1',
                        tension: 0.4,
                        fill: false,
                        borderDash: [5, 5],
                        pointRadius: 4,
                        pointBackgroundColor: '#6366f1'
                    }
                ]
            },
            options: {
                maintainAspectRatio: false,
                scales: {
                    y: {
                        grid: { color: 'rgba(99, 102, 241, 0.1)' },
                        ticks: { color: '#71717a', font: { family: 'Inter' } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#71717a', font: { family: 'Inter' } }
                    }
                },
                plugins: {
                    legend: {
                        display: true,
                        labels: {
                            color: '#a1a1aa',
                            font: { family: 'Inter' },
                            usePointStyle: true
                        }
                    }
                }
            }
        });

        // Filter Logic
        function runFilters() {
            const search = document.getElementById("mainSearch").value.toUpperCase();
            const fromD = document.getElementById("fDate").value;
            const toD = document.getElementById("tDate").value;
            const minVal = parseFloat(document.getElementById("minA").value) || 0;
            const maxVal = parseFloat(document.getElementById("maxA").value) || 9999999;

            document.querySelectorAll(".row-item").forEach(row => {
                const text = row.innerText.toUpperCase();
                const amt = parseFloat(row.dataset.amt);
                const date = row.dataset.date;

                const mSearch = text.includes(search);
                const mAmt = amt >= minVal && amt <= maxVal;
                let mDate = true;
                if (fromD && date < fromD) mDate = false;
                if (toD && date > toD) mDate = false;

                row.style.display = (mSearch && mAmt && mDate) ? "" : "none";
            });
        }
    </script>
</body>
</html>
