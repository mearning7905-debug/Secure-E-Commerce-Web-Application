<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | SmartPay Fraud Detection</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #0f1117;
            min-height: 100vh;
            color: #e4e4e7;
            display: flex;
        }

        /* =============== SIDEBAR =============== */
        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, #0a0e27 0%, #161a2f 100%);
            border-right: 2px solid rgba(99, 102, 241, 0.2);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 200;
            transition: transform 0.3s;
            box-shadow: 2px 0 15px rgba(0, 0, 0, 0.3);
        }

        .sidebar-header {
            padding: 28px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            border-bottom: 2px solid rgba(99, 102, 241, 0.15);
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(139, 92, 246, 0.05));
        }

        .sidebar-logo {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, #7c3aed, #6366f1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 800;
            color: white;
            box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
        }

        .sidebar-brand {
            font-size: 20px;
            font-weight: 800;
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 0.5px;
        }

        .sidebar-collapse {
            margin-left: auto;
            background: rgba(99, 102, 241, 0.1);
            border: 1px solid rgba(99, 102, 241, 0.2);
            color: #a78bfa;
            cursor: pointer;
            font-size: 14px;
            padding: 6px 8px;
            transition: all 0.2s;
            border-radius: 8px;
        }

        .sidebar-collapse:hover {
            background: rgba(99, 102, 241, 0.2);
            transform: translateX(-2px);
        }

        .sidebar-label {
            padding: 24px 20px 12px;
            font-size: 10px;
            font-weight: 700;
            color: #a1a1aa;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .sidebar-nav {
            flex: 1;
            padding: 8px 12px;
            overflow-y: auto;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border-radius: 12px;
            color: #cbd5e1;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 6px;
            border: 1px solid transparent;
            background: none;
            width: 100%;
            text-align: left;
            position: relative;
        }

        .nav-item:hover {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(139, 92, 246, 0.1));
            color: #fbbf24;
            border-color: rgba(251, 191, 36, 0.3);
            transform: translateX(4px);
        }

        .nav-item.active {
            background: linear-gradient(135deg, rgba(251, 191, 36, 0.2), rgba(245, 158, 11, 0.15));
            color: #fbbf24;
            font-weight: 600;
            border-color: #fbbf24;
            box-shadow: inset 0 0 10px rgba(251, 191, 36, 0.1);
        }

        .nav-item i {
            width: 20px;
            text-align: center;
            font-size: 17px;
            transition: all 0.3s;
        }

        .nav-item:hover i {
            transform: scale(1.15);
        }

        .nav-item.active i {
            color: #fbbf24;
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 2px solid rgba(99, 102, 241, 0.1);
            background: linear-gradient(180deg, transparent, rgba(139, 92, 246, 0.05));
        }

        .nav-item.logout-item {
            color: #f87171;
        }

        .nav-item.logout-item:hover {
            background: rgba(239, 68, 68, 0.12);
            color: #fca5a5;
            border-color: #fca5a5;
        }

        /* =============== MAIN AREA =============== */
        .main-area {
            flex: 1;
            margin-left: 280px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* =============== TOP BAR =============== */
        .top-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 32px;
            background: rgba(22, 26, 37, 0.95);
            border-bottom: 1px solid rgba(99, 102, 241, 0.1);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .top-search {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(15, 17, 23, 0.8);
            border: 1px solid rgba(99, 102, 241, 0.15);
            border-radius: 10px;
            padding: 0 16px;
            width: 320px;
            transition: border-color 0.3s;
        }

        .top-search:focus-within {
            border-color: #6366f1;
        }

        .top-search i {
            color: #52525b;
            font-size: 14px;
        }

        .top-search input {
            flex: 1;
            background: none;
            border: none;
            padding: 10px 8px;
            color: #fafafa;
            font-size: 14px;
            outline: none;
            font-family: 'Inter', sans-serif;
        }

        .top-search input::placeholder {
            color: #52525b;
        }

        .top-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .top-icon-btn {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(15, 17, 23, 0.6);
            border: 1px solid rgba(99, 102, 241, 0.1);
            color: #a1a1aa;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
            font-size: 16px;
        }

        .top-icon-btn:hover {
            background: rgba(99, 102, 241, 0.1);
            color: #a78bfa;
            border-color: rgba(99, 102, 241, 0.3);
        }

        .notif-dot {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 8px;
            height: 8px;
            background: #ef4444;
            border-radius: 50%;
            border: 2px solid #161a25;
        }

        .top-avatar {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 15px;
            color: white;
            cursor: pointer;
            border: 2px solid rgba(99, 102, 241, 0.3);
        }

        /* =============== PAGE CONTENT =============== */
        .page-content {
            padding: 28px 32px;
            flex: 1;
        }

        /* =============== WELCOME BANNER =============== */
        .welcome-banner {
            background: linear-gradient(135deg, #4338ca 0%, #6366f1 40%, #7c3aed 100%);
            border-radius: 18px;
            padding: 36px 40px;
            margin-bottom: 28px;
            position: relative;
            overflow: hidden;
        }

        .welcome-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 50%;
        }

        .welcome-banner::after {
            content: '';
            position: absolute;
            bottom: -30%;
            right: 10%;
            width: 200px;
            height: 200px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 50%;
        }

        .welcome-banner h1 {
            font-size: 28px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 8px;
            position: relative;
            z-index: 1;
        }

        .welcome-banner p {
            color: rgba(255, 255, 255, 0.8);
            font-size: 15px;
            line-height: 1.6;
            max-width: 600px;
            position: relative;
            z-index: 1;
            margin-bottom: 20px;
        }

        .banner-actions {
            display: flex;
            gap: 12px;
            position: relative;
            z-index: 1;
        }

        .banner-btn {
            padding: 10px 22px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            border: none;
            font-family: 'Inter', sans-serif;
        }

        .banner-btn.primary {
            background: white;
            color: #4338ca;
        }

        .banner-btn.primary:hover {
            background: #f0f0ff;
            transform: translateY(-1px);
        }

        .banner-btn.secondary {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .banner-btn.secondary:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: translateY(-1px);
        }

        /* =============== STAT CARDS =============== */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            border-radius: 16px;
            padding: 22px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
            transition: transform 0.25s, box-shadow 0.25s;
        }

        .stat-card:hover {
            transform: translateY(-3px);
        }

        .stat-card .stat-text {
            z-index: 1;
        }

        .stat-card .stat-label {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 6px;
        }

        .stat-card .stat-value {
            font-size: 30px;
            font-weight: 800;
        }

        .stat-card .stat-icon {
            font-size: 28px;
            opacity: 0.9;
            z-index: 1;
        }

        /* Card 1 — Users (Green) */
        .stat-card.card-users {
            background: linear-gradient(135deg, #059669, #10b981);
            color: white;
            box-shadow: 0 8px 24px rgba(16, 185, 129, 0.25);
        }

        /* Card 2 — Transactions (Blue) */
        .stat-card.card-transactions {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            color: white;
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.25);
        }

        /* Card 3 — Fraud Blocked (Orange) */
        .stat-card.card-blocked {
            background: linear-gradient(135deg, #d97706, #f59e0b);
            color: white;
            box-shadow: 0 8px 24px rgba(245, 158, 11, 0.25);
        }

        /* Card 4 — Revenue (Pink/Rose) */
        .stat-card.card-revenue {
            background: linear-gradient(135deg, #e11d48, #f43f5e);
            color: white;
            box-shadow: 0 8px 24px rgba(244, 63, 94, 0.25);
        }

        /* =============== CONTENT GRID =============== */
        .content-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 24px;
        }

        .panel {
            background: #161a25;
            border: 1px solid rgba(99, 102, 241, 0.1);
            border-radius: 16px;
            overflow: hidden;
        }

        .panel-header {
            padding: 20px 24px;
            border-bottom: 1px solid rgba(99, 102, 241, 0.08);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .panel-title {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 16px;
            font-weight: 600;
            color: #fafafa;
        }

        .panel-title i {
            color: #6366f1;
            font-size: 18px;
        }

        .panel-subtitle {
            font-size: 12px;
            color: #71717a;
            margin-top: 2px;
        }

        .panel-badge {
            background: rgba(99, 102, 241, 0.15);
            color: #a78bfa;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        /* =============== USERS PANEL =============== */
        .search-box {
            display: flex;
            align-items: center;
            background: rgba(15, 17, 23, 0.8);
            border: 1px solid rgba(99, 102, 241, 0.15);
            border-radius: 10px;
            padding: 0 14px;
            margin: 16px 20px;
            transition: border-color 0.3s;
        }

        .search-box:focus-within {
            border-color: #6366f1;
        }

        .search-box i {
            color: #52525b;
            font-size: 14px;
        }

        .search-box input {
            flex: 1;
            background: none;
            border: none;
            padding: 10px;
            color: #fafafa;
            font-size: 13px;
            outline: none;
            font-family: 'Inter', sans-serif;
        }

        .search-box input::placeholder {
            color: #52525b;
        }

        .users-list {
            max-height: 420px;
            overflow-y: auto;
            padding: 8px 12px 16px;
        }

        .users-list::-webkit-scrollbar {
            width: 5px;
        }

        .users-list::-webkit-scrollbar-track {
            background: transparent;
        }

        .users-list::-webkit-scrollbar-thumb {
            background: rgba(99, 102, 241, 0.25);
            border-radius: 3px;
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 14px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 6px;
            border: 1px solid transparent;
        }

        .user-card:hover {
            background: rgba(99, 102, 241, 0.08);
            border-color: rgba(99, 102, 241, 0.15);
        }

        .user-card.active {
            background: rgba(99, 102, 241, 0.12);
            border-color: #6366f1;
        }

        .user-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 16px;
            color: white;
            flex-shrink: 0;
        }

        .user-avatar.av-1 { background: linear-gradient(135deg, #6366f1, #8b5cf6); }
        .user-avatar.av-2 { background: linear-gradient(135deg, #ec4899, #f43f5e); }
        .user-avatar.av-3 { background: linear-gradient(135deg, #10b981, #059669); }
        .user-avatar.av-4 { background: linear-gradient(135deg, #f59e0b, #d97706); }
        .user-avatar.av-5 { background: linear-gradient(135deg, #3b82f6, #2563eb); }

        .user-info {
            flex: 1;
            min-width: 0;
        }

        .user-name {
            font-weight: 600;
            font-size: 14px;
            color: #fafafa;
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-email {
            font-size: 12px;
            color: #71717a;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            background: rgba(16, 185, 129, 0.15);
            color: #10b981;
        }

        /* =============== RECENT TRANSACTIONS PANEL =============== */
        .tx-list {
            padding: 8px 16px 16px;
        }

        .tx-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 0;
            border-bottom: 1px solid rgba(99, 102, 241, 0.06);
        }

        .tx-item:last-child {
            border-bottom: none;
        }

        .tx-icon-wrap {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .tx-icon-wrap.tx-success {
            background: rgba(16, 185, 129, 0.12);
            color: #10b981;
        }

        .tx-icon-wrap.tx-blocked {
            background: rgba(239, 68, 68, 0.12);
            color: #ef4444;
        }

        .tx-details {
            flex: 1;
            min-width: 0;
        }

        .tx-item-name {
            font-size: 14px;
            font-weight: 600;
            color: #fafafa;
            margin-bottom: 2px;
        }

        .tx-meta {
            font-size: 12px;
            color: #71717a;
        }

        .tx-amount {
            text-align: right;
        }

        .tx-amount-value {
            font-size: 14px;
            font-weight: 700;
            color: #fafafa;
            margin-bottom: 2px;
        }

        .tx-status {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
        }

        .tx-status.success {
            background: rgba(16, 185, 129, 0.12);
            color: #10b981;
        }

        .tx-status.blocked {
            background: rgba(239, 68, 68, 0.12);
            color: #ef4444;
        }

        .no-data {
            text-align: center;
            padding: 40px 20px;
            color: #52525b;
            font-size: 14px;
        }

        .no-data i {
            font-size: 36px;
            margin-bottom: 12px;
            display: block;
            opacity: 0.4;
        }

        .view-all-btn {
            display: block;
            text-align: center;
            padding: 14px;
            background: rgba(99, 102, 241, 0.06);
            color: #6366f1;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            border: none;
            width: 100%;
            border-top: 1px solid rgba(99, 102, 241, 0.08);
            font-family: 'Inter', sans-serif;
            transition: background 0.2s;
        }

        .view-all-btn:hover {
            background: rgba(99, 102, 241, 0.12);
        }

        /* =============== USER DETAIL MODAL =============== */
        .detail-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(4px);
            z-index: 500;
            align-items: center;
            justify-content: center;
        }

        .detail-overlay.show {
            display: flex;
        }

        .detail-modal {
            background: #1a1f2e;
            border: 1px solid rgba(99, 102, 241, 0.2);
            border-radius: 20px;
            width: 720px;
            max-width: 90vw;
            max-height: 85vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            animation: modalIn 0.25s ease-out;
        }

        @keyframes modalIn {
            from { opacity: 0; transform: scale(0.95) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        .detail-modal::-webkit-scrollbar {
            width: 5px;
        }

        .detail-modal::-webkit-scrollbar-thumb {
            background: rgba(99, 102, 241, 0.3);
            border-radius: 3px;
        }

        .modal-header {
            padding: 24px 28px;
            border-bottom: 1px solid rgba(99, 102, 241, 0.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .modal-user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .modal-avatar {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 22px;
            color: white;
        }

        .modal-name {
            font-size: 20px;
            font-weight: 700;
            color: #fafafa;
            margin-bottom: 2px;
        }

        .modal-id {
            font-size: 13px;
            color: #71717a;
        }

        .modal-close {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #ef4444;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 16px;
        }

        .modal-close:hover {
            background: #ef4444;
            color: white;
        }

        .modal-body {
            padding: 24px 28px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .info-card {
            background: rgba(15, 17, 23, 0.6);
            border: 1px solid rgba(99, 102, 241, 0.08);
            border-radius: 12px;
            padding: 16px;
        }

        .info-card .label {
            font-size: 11px;
            color: #71717a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
            font-weight: 500;
        }

        .info-card .value {
            font-size: 15px;
            font-weight: 600;
            color: #fafafa;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-success {
            background: rgba(16, 185, 129, 0.15);
            color: #10b981;
        }

        .status-blocked {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
        }

        .modal-actions {
            display: flex;
            gap: 10px;
            margin-bottom: 24px;
        }

        .action-btn {
            padding: 10px 20px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            font-family: 'Inter', sans-serif;
        }

        .btn-export {
            background: rgba(16, 185, 129, 0.12);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.25);
        }

        .btn-export:hover {
            background: #10b981;
            color: white;
        }

        .btn-delete {
            background: rgba(239, 68, 68, 0.12);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.25);
        }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
        }

        .modal-section-title {
            font-size: 15px;
            font-weight: 600;
            color: #fafafa;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .modal-section-title i {
            color: #6366f1;
        }

        .modal-tx-table {
            width: 100%;
            border-collapse: collapse;
        }

        .modal-tx-table th {
            text-align: left;
            padding: 12px 14px;
            font-size: 11px;
            font-weight: 600;
            color: #71717a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: rgba(15, 17, 23, 0.6);
            border-bottom: 1px solid rgba(99, 102, 241, 0.08);
        }

        .modal-tx-table th:first-child {
            border-radius: 8px 0 0 0;
        }

        .modal-tx-table th:last-child {
            border-radius: 0 8px 0 0;
        }

        .modal-tx-table td {
            padding: 14px;
            font-size: 13px;
            border-bottom: 1px solid rgba(99, 102, 241, 0.04);
        }

        .modal-tx-table tbody tr {
            transition: background 0.15s;
        }

        .modal-tx-table tbody tr:hover {
            background: rgba(99, 102, 241, 0.04);
        }

        .amount-cell {
            font-weight: 700;
            color: #fafafa;
        }

        .hidden {
            display: none !important;
        }

        /* =============== RESPONSIVE =============== */
        @media (max-width: 1200px) {
            .stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
            .content-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .main-area {
                margin-left: 0;
            }
            .stats-row {
                grid-template-columns: 1fr;
            }
            .page-content {
                padding: 20px 16px;
            }
            .top-search {
                width: 200px;
            }
            .welcome-banner {
                padding: 28px 24px;
            }
            .welcome-banner h1 {
                font-size: 22px;
            }
            .info-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">S</div>
            <span class="sidebar-brand">SmartPay</span>
            <button class="sidebar-collapse" title="Collapse"><i class="fa-solid fa-chevron-left"></i></button>
        </div>

        <div class="sidebar-label">Main Menu</div>
        <nav class="sidebar-nav">
            <a class="nav-item active" href="#welcome-banner" onclick="document.getElementById('welcome-banner').scrollIntoView({behavior:'smooth'})">
                <i class="fa-solid fa-grid-2"></i> Dashboard
            </a>
            <a class="nav-item" href="#users-panel" onclick="document.getElementById('users-panel').scrollIntoView({behavior:'smooth'})">
                <i class="fa-solid fa-users"></i> Users
            </a>
            <a class="nav-item" href="#tx-panel" onclick="document.getElementById('tx-panel').scrollIntoView({behavior:'smooth'})">
                <i class="fa-solid fa-right-left"></i> Transactions
            </a>
            <a class="nav-item" href="#stats-row" onclick="document.getElementById('stats-row').scrollIntoView({behavior:'smooth'})">
                <i class="fa-solid fa-chart-line"></i> Analytics
            </a>
        </nav>

        <div class="sidebar-footer">
            <a class="nav-item" href="/">
                <i class="fa-solid fa-house"></i> Back to Store
            </a>
            <a class="nav-item logout-item" href="/logout">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </a>
        </div>
    </aside>

    <!-- ===== MAIN AREA ===== -->
    <div class="main-area">
        <!-- Top Bar -->
        <header class="top-bar">
            <div class="top-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Search users, transactions..." id="globalSearch" onkeyup="filterUsers()">
            </div>
            <div class="top-actions">
                <button class="top-icon-btn" title="Notifications">
                    <i class="fa-solid fa-bell"></i>
                    {% if stats.blocked_count > 0 %}
                    <span class="notif-dot"></span>
                    {% endif %}
                </button>
                <button class="top-icon-btn" title="Messages">
                    <i class="fa-solid fa-comment-dots"></i>
                </button>
                <div class="top-avatar" title="Admin">A</div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="page-content">
            <!-- Welcome Banner -->
            <div class="welcome-banner" id="welcome-banner">
                <h1>Welcome to SmartPay Admin</h1>
                <p>Monitor transactions, detect fraud in real-time, and manage your users. Stay on top of everything with your comprehensive dashboard.</p>
                <div class="banner-actions">
                    <a class="banner-btn primary" href="/history">View Analytics</a>
                    <a class="banner-btn secondary" href="/shop">Visit Store</a>
                </div>
            </div>

            <!-- Stat Cards -->
            <div class="stats-row" id="stats-row">
                <div class="stat-card card-users">
                    <div class="stat-text">
                        <div class="stat-label">Total Users</div>
                        <div class="stat-value">{{ stats.total_users }}</div>
                    </div>
                    <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
                </div>
                <div class="stat-card card-transactions">
                    <div class="stat-text">
                        <div class="stat-label">Total Transactions</div>
                        <div class="stat-value">{{ stats.total_transactions }}</div>
                    </div>
                    <div class="stat-icon"><i class="fa-solid fa-right-left"></i></div>
                </div>
                <div class="stat-card card-blocked">
                    <div class="stat-text">
                        <div class="stat-label">Fraud Blocked</div>
                        <div class="stat-value">{{ stats.blocked_count }}</div>
                    </div>
                    <div class="stat-icon"><i class="fa-solid fa-shield-halved"></i></div>
                </div>
                <div class="stat-card card-revenue">
                    <div class="stat-text">
                        <div class="stat-label">Revenue</div>
                        <div class="stat-value">₹{{ stats.total_revenue }}</div>
                    </div>
                    <div class="stat-icon"><i class="fa-solid fa-heart"></i></div>
                </div>
            </div>

            <!-- Content Grid -->
            <div class="content-grid">
                <!-- Recent Transactions Panel -->
                <div class="panel" id="tx-panel">
                    <div class="panel-header">
                        <div>
                            <div class="panel-title"><i class="fa-solid fa-clock-rotate-left"></i> Recent Transactions</div>
                            <div class="panel-subtitle">Latest payment activity across all users</div>
                        </div>
                    </div>
                    <div class="tx-list">
                        {% if transactions|length > 0 %}
                            {% for tx in transactions[-8:]|reverse %}
                            <div class="tx-item">
                                {% if '✅' in tx.status or 'Successful' in tx.status %}
                                <div class="tx-icon-wrap tx-success"><i class="fa-solid fa-check"></i></div>
                                {% else %}
                                <div class="tx-icon-wrap tx-blocked"><i class="fa-solid fa-xmark"></i></div>
                                {% endif %}
                                <div class="tx-details">
                                    <div class="tx-item-name">{{ tx.item_name or 'Product' }}</div>
                                    <div class="tx-meta">{{ tx.email }} · {{ tx.time }}</div>
                                </div>
                                <div class="tx-amount">
                                    <div class="tx-amount-value">₹{{ tx.amount }}</div>
                                    {% if '✅' in tx.status or 'Successful' in tx.status %}
                                    <span class="tx-status success"><i class="fa-solid fa-check-circle"></i> Success</span>
                                    {% else %}
                                    <span class="tx-status blocked"><i class="fa-solid fa-ban"></i> Blocked</span>
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        {% else %}
                            <div class="no-data">
                                <i class="fa-solid fa-receipt"></i>
                                No transactions yet
                            </div>
                        {% endif %}
                    </div>
                    {% if transactions|length > 0 %}
                    <a href="/history" class="view-all-btn">View All Transactions</a>
                    {% endif %}
                </div>

                <!-- Registered Users Panel -->
                <div class="panel" id="users-panel">
                    <div class="panel-header">
                        <div>
                            <div class="panel-title"><i class="fa-solid fa-user-group"></i> Registered Users</div>
                            <div class="panel-subtitle">Click a user to view full details</div>
                        </div>
                        <span class="panel-badge">{{ stats.total_users }}</span>
                    </div>
                    <div class="search-box">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="userSearch" placeholder="Search users..." onkeyup="filterUsers()">
                    </div>
                    <div class="users-list" id="usersList">
                        {% for user in db_users %}
                        <div class="user-card" data-name="{{ user.username }}" data-email="{{ user.email }}"
                            onclick="viewUser('{{ user.id }}', '{{ user.username }}', '{{ user.email }}', '{{ user.mobile }}', '{{ user.card }}')">
                            <div class="user-avatar av-{{ loop.index % 5 + 1 }}">{{ user.username[0]|upper }}</div>
                            <div class="user-info">
                                <div class="user-name">{{ user.username }}</div>
                                <div class="user-email">{{ user.email }}</div>
                            </div>
                            <span class="user-badge">Active</span>
                        </div>
                        {% endfor %}

                        {% if db_users|length == 0 %}
                        <div class="no-data">
                            <i class="fa-solid fa-user-plus"></i>
                            No users registered yet
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== USER DETAIL MODAL ===== -->
    <div class="detail-overlay" id="detail-overlay" onclick="closeModal(event)">
        <div class="detail-modal" onclick="event.stopPropagation()">
            <div class="modal-header">
                <div class="modal-user-info">
                    <div class="modal-avatar" id="display-avatar">M</div>
                    <div>
                        <div class="modal-name" id="display-name">User Name</div>
                        <div class="modal-id">ID: <span id="display-id">1</span></div>
                    </div>
                </div>
                <button class="modal-close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="modal-body">
                <!-- Info Grid -->
                <div class="info-grid">
                    <div class="info-card">
                        <div class="label">Email Address</div>
                        <div class="value" id="display-email">user@example.com</div>
                    </div>
                    <div class="info-card">
                        <div class="label">Mobile Number</div>
                        <div class="value" id="display-mobile">+91 XXXXXXXXXX</div>
                    </div>
                    <div class="info-card">
                        <div class="label">Card Number</div>
                        <div class="value" id="display-card">**** **** **** 1234</div>
                    </div>
                    <div class="info-card">
                        <div class="label">Account Status</div>
                        <div class="value">
                            <span class="status-badge status-success"><i class="fa-solid fa-circle-check"></i> Active</span>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="modal-actions">
                    <button class="action-btn btn-export" onclick="exportUserData()">
                        <i class="fa-solid fa-download"></i> Export
                    </button>
                    <button class="action-btn btn-delete" onclick="deleteUser()">
                        <i class="fa-solid fa-trash"></i> Delete User
                    </button>
                </div>

                <!-- Transactions -->
                <div class="modal-section-title"><i class="fa-solid fa-clock-rotate-left"></i> Transaction History</div>
                <table class="modal-tx-table">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Amount</th>
                            <th>Bank</th>
                            <th>Status</th>
                            <th>Date & Time</th>
                        </tr>
                    </thead>
                    <tbody id="transactions-body">
                    </tbody>
                </table>
                <div id="no-transactions" class="no-data hidden">
                    <i class="fa-solid fa-receipt"></i>
                    No transactions found for this user
                </div>
            </div>
        </div>
    </div>

    <script>
        const userTransactions = {{ user_transactions | tojson | safe }};
        let selectedUserData = null;

        // Filter Users
        function filterUsers() {
            const searchVal = (document.getElementById('userSearch').value + document.getElementById('globalSearch').value).toLowerCase();
            const cards = document.querySelectorAll('.user-card');

            cards.forEach(card => {
                const name = card.dataset.name.toLowerCase();
                const email = card.dataset.email.toLowerCase();

                if (name.includes(searchVal) || email.includes(searchVal)) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // View User Details — opens modal
        function viewUser(id, username, email, mobile, card) {
            // Remove active from all cards
            document.querySelectorAll('.user-card').forEach(c => c.classList.remove('active'));
            event.currentTarget.classList.add('active');

            // Set user data in modal
            document.getElementById('display-avatar').textContent = username.charAt(0).toUpperCase();
            document.getElementById('display-name').textContent = username;
            document.getElementById('display-id').textContent = id;
            document.getElementById('display-email').textContent = email;
            document.getElementById('display-mobile').textContent = mobile;
            document.getElementById('display-card').textContent = '**** **** **** ' + card.slice(-4);

            selectedUserData = { id, username, email, mobile, card };
            window.selectedUserId = id;

            loadTransactions(email);

            // Show modal
            document.getElementById('detail-overlay').classList.add('show');
        }

        // Close modal
        function closeModal(e) {
            if (!e || e.target === document.getElementById('detail-overlay')) {
                document.getElementById('detail-overlay').classList.remove('show');
            }
        }

        // Load Transactions
        function loadTransactions(email) {
            const tbody = document.getElementById('transactions-body');
            const noTx = document.getElementById('no-transactions');

            tbody.innerHTML = '';

            if (userTransactions[email] && userTransactions[email].length > 0) {
                noTx.classList.add('hidden');
                tbody.parentElement.classList.remove('hidden');

                userTransactions[email].forEach(tx => {
                    const isSuccess = tx.status.includes('Successful') || tx.status.includes('Success');
                    const statusClass = isSuccess ? 'status-success' : 'status-blocked';
                    const statusIcon = isSuccess ? '<i class="fa-solid fa-check-circle"></i>' : '<i class="fa-solid fa-ban"></i>';
                    const statusText = isSuccess ? 'Success' : 'Blocked';

                    tbody.innerHTML += `
                        <tr>
                            <td>${tx.item_name || 'Product'}</td>
                            <td class="amount-cell">₹${tx.amount}</td>
                            <td>${tx.bank_name || 'N/A'}</td>
                            <td>
                                <span class="status-badge ${statusClass}">
                                    ${statusIcon} ${statusText}
                                </span>
                            </td>
                            <td>${tx.time}</td>
                        </tr>
                    `;
                });
            } else {
                noTx.classList.remove('hidden');
            }
        }

        // Delete User
        function deleteUser() {
            if (!window.selectedUserId) {
                alert("Please select a user first");
                return;
            }

            if (!confirm("Are you sure you want to delete this user? This action cannot be undone.")) {
                return;
            }

            fetch("/delete-user/" + window.selectedUserId, {
                method: "POST"
            })
                .then(res => res.json())
                .then(data => {
                    alert(data.message);
                    location.reload();
                })
                .catch(err => {
                    alert("Error deleting user");
                });
        }

        // Export User Data
        function exportUserData() {
            if (!selectedUserData) {
                alert("Please select a user first");
                return;
            }

            const data = {
                ...selectedUserData,
                transactions: userTransactions[selectedUserData.email] || []
            };

            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `user_${selectedUserData.username}_data.json`;
            a.click();
            URL.revokeObjectURL(url);
        }

        // Escape key closes modal
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') closeModal();
        });
    </script>
</body>

</html>
